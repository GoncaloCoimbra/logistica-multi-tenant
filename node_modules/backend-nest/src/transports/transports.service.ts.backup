import { Injectable, NotFoundException } from '@nestjs/common';
import { TransportRepository } from '../database/repositories/transport.repository';

@Injectable()
export class TransportsService {
  constructor(private transportRepository: TransportRepository) {}

  async create(createTransportDto: any) {
    return this.transportRepository.create(createTransportDto);
  }

  async findAll() {
    return this.transportRepository.findAll();
  }

  async findOne(id: string) {
    const transport = await this.transportRepository.findOne({ id });

    if (!transport) {
      throw new NotFoundException(\Transport with ID \ not found\);
    }

    return transport;
  }

  async findByCompany(companyId: string) {
    return this.transportRepository.findByCompany(companyId);
  }

  async findByStatus(status: string) {
    return this.transportRepository.findByStatus(status);
  }

  async update(id: string, updateTransportDto: any) {
    const transport = await this.transportRepository.findOne({ id });

    if (!transport) {
      throw new NotFoundException(\Transport with ID \ not found\);
    }

    return this.transportRepository.update({ id }, updateTransportDto);
  }

  async remove(id: string) {
    const transport = await this.transportRepository.findOne({ id });

    if (!transport) {
      throw new NotFoundException(\Transport with ID \ not found\);
    }

    return this.transportRepository.delete({ id });
  }
}
