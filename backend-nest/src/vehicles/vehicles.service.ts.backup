import { Injectable, NotFoundException } from '@nestjs/common';
import { VehicleRepository } from '../database/repositories/vehicle.repository';

@Injectable()
export class VehiclesService {
  constructor(private vehicleRepository: VehicleRepository) {}

  async create(createVehicleDto: any) {
    return this.vehicleRepository.create(createVehicleDto);
  }

  async findAll() {
    return this.vehicleRepository.findAll();
  }

  async findOne(id: string) {
    const vehicle = await this.vehicleRepository.findOne({ id });

    if (!vehicle) {
      throw new NotFoundException(\Vehicle with ID \ not found\);
    }

    return vehicle;
  }

  async findByCompany(companyId: string) {
    return this.vehicleRepository.findByCompany(companyId);
  }

  async findAvailable() {
    return this.vehicleRepository.findAvailable();
  }

  async update(id: string, updateVehicleDto: any) {
    const vehicle = await this.vehicleRepository.findOne({ id });

    if (!vehicle) {
      throw new NotFoundException(\Vehicle with ID \ not found\);
    }

    return this.vehicleRepository.update({ id }, updateVehicleDto);
  }

  async remove(id: string) {
    const vehicle = await this.vehicleRepository.findOne({ id });

    if (!vehicle) {
      throw new NotFoundException(\Vehicle with ID \ not found\);
    }

    return this.vehicleRepository.delete({ id });
  }
}
