generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id            String         @id @default(uuid())
  name          String
  nif           String         @unique
  email         String         @unique
  phone         String?
  address       String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditLogs     AuditLog[]
  notifications Notification[]
  products      Product[]
  settings      Settings?
  suppliers     Supplier[]
  transports    Transport[]
  users         User[]
  vehicles      Vehicle[]
  tasks         Task[]
  referrals     Referral[]
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  name             String
  password         String
  role             Role              @default(OPERATOR)
  isActive         Boolean           @default(true)
  avatarUrl        String?           
  companyId        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  auditLogs        AuditLog[]
  notifications    Notification[]
  productMovements ProductMovement[]
  refreshTokens    RefreshToken[]
  createdTasks     Task[]
  company          Company           @relation(fields: [companyId], references: [id])
}

model Supplier {
  id        String    @id @default(uuid())
  name      String
  nif       String
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  company   Company   @relation(fields: [companyId], references: [id])
}

model Product {
  id               String             @id @default(uuid())
  internalCode     String
  description      String
  quantity         Float
  unit             String
  totalWeight      Float?
  totalVolume      Float?
  currentLocation  String?
  status           ProductStatus      @default(RECEIVED)
  supplierId       String
  companyId        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  company          Company            @relation(fields: [companyId], references: [id])
  supplier         Supplier           @relation(fields: [supplierId], references: [id])
  movements        ProductMovement[]
  transportProducts TransportProduct[]

  @@unique([internalCode, companyId])
}

model ProductMovement {
  id             String        @id @default(uuid())
  productId      String
  previousStatus ProductStatus
  newStatus      ProductStatus
  quantity       Float
  location       String
  reason         String?
  userId         String
  createdAt      DateTime      @default(now())
  product        Product       @relation(fields: [productId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Vehicle {
  id           String        @id @default(uuid())
  licensePlate String
  type         String
  model        String
  brand        String
  capacity     Float
  year         Int
  status       VehicleStatus @default(available)
  companyId    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transports   Transport[]
  company      Company       @relation(fields: [companyId], references: [id])

  @@unique([licensePlate, companyId])
}

model Transport {
  id               String             @id @default(uuid())
  internalCode     String             @unique
  vehicleId        String
  origin           String
  destination      String
  departureDate    DateTime
  estimatedArrival DateTime
  actualArrival    DateTime?
  receivedBy       String?
  receivingNotes   String?
  totalWeight      Float
  notes            String?
  companyId        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  status           TransportStatus    @default(PENDING)
  company          Company            @relation(fields: [companyId], references: [id])
  vehicle          Vehicle            @relation(fields: [vehicleId], references: [id])
  products         TransportProduct[]
}

model TransportProduct {
  id          String    @id @default(uuid())
  transportId String
  productId   String
  quantity    Float
  createdAt   DateTime  @default(now())
  
  transport   Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])
  
  @@unique([transportId, productId])
  @@index([transportId])
  @@index([productId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  ipAddress String?
  userId    String
  companyId String
  data      Json?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Settings {
  id        String   @id @default(uuid())
  companyId String   @unique
  taxRate   Float?   @default(0.23)
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  content   String
  isRead    Boolean  @default(false)
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  company   Company  @relation(fields: [companyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime
  assignedTo  String?
  companyId   String
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}

model Referral {
  id              String         @id @default(uuid())
  clientName      String
  contactInfo     String
  referralSource  String
  projectType     String
  estimatedValue  Float
  referralDate    DateTime
  notes           String?
  referredBy      String         // Nome de quem referenciou
  commission      Float?
  status          ReferralStatus @default(NEW)
  companyId       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  company         Company        @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([status])
}

enum ReferralStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
}

enum ProductStatus {
  RECEIVED
  IN_ANALYSIS
  IN_STORAGE
  APPROVED
  DISPATCHED
}

enum VehicleStatus {
  available
  in_use
  in_maintenance
  retired
}

enum TransportStatus {
  PENDING
  IN_TRANSIT
  ARRIVED      
  DELIVERED
  CANCELED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

